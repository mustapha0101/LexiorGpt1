# ----------------------------------------------------------------------
# Configuration Globale de l'Infrastructure de Production LexiorGPT
# Copiez ce fichier sous le nom '.env' et configurez vos valeurs secrètes.
# ----------------------------------------------------------------------

# 1. Jetons Hugging Face
# Nécessaire pour télécharger les modèles distillés privés
HF_TOKEN=votre_token_hugging_face_lecture

# 2. Modèle d'inférence cible
# Par exemple: Qwen/Qwen2.5-32B-Instruct-AWQ ou le chemin de votre modèle distillé
GEN_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ

# 3. Sécurité LiteLLM Gateway
# Clé d'administration pour créer/supprimer des clés d'accès clients
LITELLM_MASTER_KEY=cle_maitre_securisee_generer_aleatoirement

# 4. Certificats SSL (Reverse Proxy Nginx)
# Chemins locaux absolus vers vos clés et certificats SSL de domaine
SSL_CERT_PATH=./certs/ssl_cert.crt
SSL_KEY_PATH=./certs/ssl_key.key
